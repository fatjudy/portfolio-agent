# Copy to .env and fill in. .env is gitignored.

# LLM provider (Anthropic). Default to the latest capable models.
ANTHROPIC_API_KEY=

# Financial sentiment API (free tier): https://finnhub.io
FINNHUB_API_KEY=

# Reddit app credentials for PRAW: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=portfolio-agent/0.1 by u_yourname

# Delivery webhook for the human-gate notification (Slack/Telegram/etc.)
NOTIFY_WEBHOOK_URL=

# yfinance needs no key.
